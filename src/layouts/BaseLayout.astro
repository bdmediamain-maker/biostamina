---
import '@/styles/global.css';
import { getLangFromUrl, useTranslations } from '@/lib/i18n';
import { canonical, alternates, orgSchema } from '@/lib/seo';
import { aggregateRating } from '@/data/reviews';
import Analytics from '@/components/Analytics.astro';
import Header from '@/components/nav/Header.astro';
import CartDrawer from '@/components/cart/CartDrawer.astro';
import SearchModal from '@/components/search/SearchModal.astro';
import Footer from '@/components/layout/Footer.astro';
import WhatsAppFab from '@/components/layout/WhatsAppFab.astro';
import AssistantSlot from '@/components/layout/AssistantSlot.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[]; // schema.org aggiuntivi (Product, Breadcrumb, Article…)
}

const { title, description, ogImage = '/og-default.jpg', type = 'website', noindex = false, jsonLd = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = Astro.url.pathname;
const alts = alternates(path);
const org = orgSchema(aggregateRating());
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical(path)} />
    {alts.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical(path)} />
    <meta property="og:image" content={canonical(ogImage)} />
    <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_GB'} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(org)} />
    {jsonLd.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <!-- Consenso (Iubenda) + Analytics (GA4 + Google Ads) — solo in produzione -->
    <Analytics />
  </head>
  <body>
    <a href="#main" class="skip-link">{t('skip')}</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFab />
    <AssistantSlot />
    <CartDrawer />
    <SearchModal />

    <!-- Lenis smooth scroll + GSAP reveal (rispetta reduced-motion) -->
    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduce) {
        gsap.registerPlugin(ScrollTrigger);
        const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
        lenis.on('scroll', ScrollTrigger.update);

        document.querySelectorAll('[data-reveal]').forEach((el) => {
          ScrollTrigger.create({
            trigger: el,
            start: 'top 85%',
            once: true,
            onEnter: () => el.classList.add('is-visible'),
          });
        });
      } else {
        document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('is-visible'));
      }

      // GlowCard: spotlight tracking + tilt 3D leggero.
      // Solo su dispositivi con mouse (hover:hover) e senza reduced-motion.
      const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      if (!reduce && canHover) {
        document.querySelectorAll<HTMLElement>('.glow-card').forEach((card) => {
          card.addEventListener('mousemove', (e) => {
            const r = card.getBoundingClientRect();
            const x = e.clientX - r.left;
            const y = e.clientY - r.top;
            card.style.setProperty('--mx', `${x}px`);
            card.style.setProperty('--my', `${y}px`);
            const rotateX = ((y - r.height / 2) / (r.height / 2)) * -5;
            const rotateY = ((x - r.width / 2) / (r.width / 2)) * 5;
            gsap.to(card, { rotateX, rotateY, duration: 0.2, ease: 'power2.out', transformPerspective: 1000 });
          });
          card.addEventListener('mouseleave', () => {
            gsap.to(card, { rotateX: 0, rotateY: 0, duration: 0.4, ease: 'power2.out' });
          });
        });
      }

      // Split-text: titoli di sezione (H2) animati lettera per lettera allo scroll
      // (fade + slide-up + riduzione blur). Mai gli hero/titoli-pagina (che sono <h1>).
      // Solo H2 di solo testo; guard reduced-motion; aria-label preserva l'accessibilità.
      if (!reduce) {
        const splitIO = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              gsap.to(e.target.querySelectorAll('.split-char'), {
                opacity: 1,
                yPercent: 0,
                filter: 'blur(0px)',
                duration: 0.5,
                ease: 'power3.out',
                stagger: 0.018,
              });
              obs.unobserve(e.target);
            });
          },
          { rootMargin: '0px 0px -12% 0px' },
        );
        document.querySelectorAll<HTMLHeadingElement>('h2:not([data-split-done])').forEach((h) => {
          if (h.children.length > 0) return; // salta titoli con markup interno
          const text = h.textContent || '';
          if (!text.trim()) return;
          h.setAttribute('data-split-done', '');
          h.setAttribute('aria-label', text);
          const frag = document.createDocumentFragment();
          for (const ch of text) {
            if (ch === ' ') { frag.appendChild(document.createTextNode(' ')); continue; }
            const s = document.createElement('span');
            s.className = 'split-char';
            s.textContent = ch;
            frag.appendChild(s);
          }
          h.replaceChildren(frag);
          gsap.set(h.querySelectorAll('.split-char'), { opacity: 0, yPercent: 45, filter: 'blur(6px)' });
          splitIO.observe(h);
        });
      }
    </script>
  </body>
</html>
