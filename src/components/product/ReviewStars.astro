---
interface Props { rating: number; count?: number; showCount?: boolean; size?: number }
const { rating, count, showCount = true, size = 16 } = Astro.props;
const full = Math.round(rating);
---
<span class="inline-flex items-center gap-1.5" role="img" aria-label={`${rating} su 5${count ? `, ${count} recensioni` : ''}`}>
  <span class="inline-flex" aria-hidden="true">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg width={size} height={size} viewBox="0 0 24 24" fill={i < full ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.4" class="text-azure">
        <path d="M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.8 6.1 20.9l1.1-6.5L2.5 9.8l6.5-.9L12 2.5Z" />
      </svg>
    ))}
  </span>
  {showCount && count != null && <span class="text-sm text-muted">{rating.toFixed(1)} ({count})</span>}
</span>
