---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, localePath, type Lang } from '@/lib/i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const it = lang === 'it';

// Modalità d'uso ufficiali dai bugiardini (già nei prodotti)
const products = (await getCollection('products', (p) => !p.data.draft)).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title={`${t('nav.howto')} — Biostamina`} description={it ? 'Modalità d’uso ufficiali dei dispositivi Bio RIGENERA® O3, dai bugiardini: uso domestico e professionale.' : 'Official directions for use of Bio RIGENERA® O3 devices, from the IFUs: home and professional use.'}>
  <div class="mx-auto max-w-4xl px-5 py-14">
    <h1 class="text-4xl md:text-5xl mb-4">{t('nav.howto')}</h1>
    <p class="text-muted mb-10 max-w-2xl">{it ? 'Le modalità d’uso riportate sono quelle ufficiali dei bugiardini. Per l’uso professionale seguire i protocolli indicati.' : 'The directions below are the official ones from the IFUs. For professional use, follow the indicated protocols.'}</p>

    <div class="space-y-6">
      {products.map((p) => {
        const loc = p.data[lang];
        return loc.usage && (
          <section class="rounded-[--radius-card] border border-hairline bg-surface p-6" data-reveal>
            {/* Badge sopra il titolo (come nella scheda prodotto): titolo serif e
                badge mono su una stessa riga non si allineano otticamente, e con i
                nomi lunghi il badge andava a capo disallineandosi del tutto. */}
            <p class="label-mono text-primary mb-2">{
              p.data.class === 'cosmetico' ? t('product.cosmetic')
              : p.data.class === 'veterinario' ? t('product.veterinary')
              : `${t('product.class')} ${p.data.class}`
            }</p>
            <h2 class="text-xl mb-3">{loc.name}</h2>
            <p class="text-sm text-ink/85 leading-relaxed">{loc.usage}</p>
            {/* I protocolli professionali NON stanno più qui: vivono nel blog,
                sezione "Il consiglio del medico sulle medicazioni" (e nella
                scheda prodotto). Richiesta cliente. */}
            <a href={localePath(lang, `prodotto/${p.id}`)} class="mt-3 inline-block text-sm text-azure hover:underline">{t('cta.viewProduct')} →</a>
          </section>
        );
      })}
    </div>

    <div class="section-blue mt-10 rounded-[--radius-card] border p-6 md:p-8 shadow-soft" data-reveal>
      <h2 class="text-lg mb-2">{t('product.warnings')}</h2>
      <p class="text-sm text-muted leading-relaxed">{it
        ? 'Leggere sempre le avvertenze complete sulla scheda di ciascun prodotto e sul bugiardino. Non utilizzare in caso di ipersensibilità nota ai componenti. Tenere fuori dalla portata dei bambini.'
        : 'Always read the full warnings on each product page and on the IFU. Do not use in case of known hypersensitivity to the components. Keep out of reach of children.'}</p>
    </div>
  </div>
</BaseLayout>
