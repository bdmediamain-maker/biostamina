---
// Root → lingua di default. Meta-refresh (SSG-safe) + link fallback.
const target = '/it/';
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href="https://biostamina.net/it/" />
    <title>Biostamina</title>
  </head>
  <body>
    <p>Redirecting to <a href={target}>Biostamina</a>…</p>
  </body>
</html>
