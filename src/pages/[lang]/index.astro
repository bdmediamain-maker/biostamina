---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import dentalShowcase from '@/assets/products/dental-showcase.jpg';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, localePath, type Lang } from '@/lib/i18n';
import { site } from '@/config/site';
import TrustRow from '@/components/layout/TrustRow.astro';
import ProductCard from '@/components/product/ProductCard.astro';
import ProReviews from '@/components/social/ProReviews.astro';
import YouTubeFeed from '@/components/social/YouTubeFeed.astro';
import GlowCard from '@/components/ui/GlowCard.astro';
import NeonButton from '@/components/ui/NeonButton.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const products = (await getCollection('products', (p) => !p.data.draft)).sort((a, b) => a.data.order - b.data.order);

// Hero: copy del cliente, strutturata per essere leggibile (una frase di 20
// parole non funziona come display type). "ProRigenera®" viene evidenziata in
// colore accento per dare all'occhio un punto d'aggancio: divido il titolo sul
// nome del marchio, che è identico in IT e EN.
const heroTitle = t('hero.title');
const [titleBefore, titleAfter = ''] = heroTitle.split('Biostamina®');

const problems = lang === 'it'
  ? [
      { t: 'Odontoiatria', d: 'Post-chirurgia, gengiviti, parodontiti, impianti.', slug: 'dental' },
      { t: 'Cicatrizzazione', d: 'Ferite, ustioni, piaghe da decubito, ulcere.', slug: 'cicatren' },
      { t: 'Dermatologia', d: 'Acne, psoriasi, dermatiti, eritemi.', slug: 'dermal' },
    ]
  : [
      { t: 'Dentistry', d: 'Post-surgery, gingivitis, parodontitis, implants.', slug: 'dental' },
      { t: 'Wound healing', d: 'Wounds, burns, pressure sores, ulcers.', slug: 'cicatren' },
      { t: 'Dermatology', d: 'Acne, psoriasis, dermatitis, erythema.', slug: 'dermal' },
    ];
---
<BaseLayout title="Biostamina — Bio RIGENERA® O3 · Dispositivi medici CE" description={site.tagline[lang]}>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <!-- pt ridotto di 20px (era pt-16 / md:pt-24) per stringere lo stacco titolo-navbar -->
    <div class="mx-auto max-w-7xl px-5 pt-[44px] pb-20 md:pt-[76px] md:pb-28 grid lg:grid-cols-[1fr_1.15fr] gap-12 items-center">
      <div>
        <p class="label-mono text-primary mb-4" data-reveal>{t('hero.eyebrow')}</p>
        <h1 class="text-2xl sm:text-3xl lg:text-[2.5rem] leading-[1.15] text-balance" data-reveal>
          {titleBefore}<span class="text-primary">Biostamina®</span>{titleAfter}
        </h1>
        <p class="mt-4 text-base text-ink/80 max-w-xl leading-relaxed" data-reveal>{t('hero.lead')}</p>
        <p class="mt-3 text-sm text-ink/75 max-w-xl leading-relaxed" data-reveal>{t('hero.natural')}</p>
        <p class="mt-3 flex gap-2.5 items-start text-sm font-medium text-ink max-w-xl leading-relaxed" data-reveal>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="text-primary shrink-0 mt-1" aria-hidden="true">
            <path d="M20 6 9 17l-5-5" />
          </svg>
          <span>{t('hero.ce')}</span>
        </p>
        <div class="mt-6 flex flex-wrap gap-3" data-reveal>
          <NeonButton href={localePath(lang, 'negozio')} variant="solid">{t('cta.discover')} →</NeonButton>
          <NeonButton href={localePath(lang, 'certificazioni')} variant="default">{t('cta.certifications')}</NeonButton>
        </div>
      </div>
      <div class="relative rounded-[--radius-card] bg-surface border border-hairline shadow-soft overflow-hidden" data-reveal>
        <Image
          src={dentalShowcase}
          alt="Bio RIGENERA® O3 Dental — confezione e prodotto"
          width={880}
          height={791}
          class="w-full h-auto"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- PRODUCT GRID — subito sotto l'hero: prima i prodotti ("i nostri") -->
  <section class="mx-auto max-w-7xl px-5 pt-4 pb-16">
    <div class="flex items-end justify-between gap-4 mb-8">
      <h2 class="text-3xl md:text-4xl" data-reveal>{t('home.productsHeading')}</h2>
      <a href={localePath(lang, 'negozio')} class="text-sm text-azure hover:underline shrink-0" data-reveal>{t('cta.allProducts')} →</a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  <!-- ATTESTAZIONI — DOPO i prodotti: prima li mostriamo, poi le prove -->
  <section class="mx-auto max-w-7xl px-5 pb-16">
    <TrustRow />
  </section>

  <!-- SLOGAN FITOTERAPIA (citazione) -->
  <section class="section-blue border-y">
    <div class="mx-auto max-w-4xl px-5 py-16 md:py-20 text-center" data-reveal>
      <span class="label-mono text-white/70">{lang === 'it' ? 'Fitoterapia' : 'Phytotherapy'}</span>
      <span class="block font-display text-6xl md:text-7xl leading-none text-white/25 mt-4 mb-1" aria-hidden="true">“</span>
      <blockquote class="font-display text-2xl md:text-4xl leading-[1.25] text-white -mt-2 text-balance">
        {lang === 'it'
          ? 'Le proprietà dei semi di pompelmo e dell’ozono svolgono un’azione antibatterica e contribuiscono ad una veloce e corretta rigenerazione del tessuto epiteliale.'
          : 'The properties of grapefruit seeds and ozone perform an antibacterial action and contribute to a fast and correct regeneration of the epithelial tissue.'}
      </blockquote>
    </div>
  </section>

  <!-- PROBLEM / SOLUTION -->
  <section class="bg-tint/40 border-y border-hairline">
    <div class="mx-auto max-w-7xl px-5 py-16">
      <h2 class="text-3xl md:text-4xl mb-3" data-reveal>{lang === 'it' ? 'Una linea, quattro ambiti clinici.' : 'One range, four clinical fields.'}</h2>
      <p class="text-muted mb-10 max-w-2xl" data-reveal>{lang === 'it' ? 'Ogni formulazione nasce dallo stesso principio rigenerante, calibrata per il tessuto da trattare.' : 'Every formula shares the same regenerating principle, calibrated for the target tissue.'}</p>
      <div class="grid gap-5 md:grid-cols-3">
        {problems.map((p) => (
          <GlowCard as="a" href={localePath(lang, `prodotto/${p.slug}`)} class="block rounded-[--radius-card] bg-surface border border-hairline p-6 transition-shadow group" data-reveal>
            <h3 class="text-xl text-ink group-hover:text-primary transition-colors">{p.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{p.d}</p>
            <span class="mt-4 inline-block text-sm text-azure font-medium">{t('cta.viewProduct')} →</span>
          </GlowCard>
        ))}
      </div>
    </div>
  </section>

  <ProReviews />

  <!-- PROFESSIONALS CTA -->
  <section class="mx-auto max-w-7xl px-5 py-16">
    <div class="rounded-[--radius-card] bg-primary text-white p-10 md:p-14 flex flex-col md:flex-row md:items-center justify-between gap-6" data-reveal>
      <div>
        <h2 class="text-3xl text-white">{lang === 'it' ? 'Sei un professionista?' : 'Are you a professional?'}</h2>
        <p class="mt-2 text-white/80 max-w-xl">{lang === 'it' ? 'Campioni, listino dedicato e protocolli clinici per studi odontoiatrici, dermatologi e strutture sanitarie.' : 'Samples, dedicated pricing and clinical protocols for dental practices, dermatologists and healthcare facilities.'}</p>
      </div>
      <NeonButton href={localePath(lang, 'professionisti')} variant="light" line="via-primary" class="shrink-0">{t('nav.professionals')} →</NeonButton>
    </div>
  </section>

  <YouTubeFeed />
</BaseLayout>
