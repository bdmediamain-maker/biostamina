---
import { getLangFromUrl, useTranslations } from '@/lib/i18n';
import { site } from '@/config/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const href = `https://wa.me/${site.whatsapp.number}`;
const label = site.whatsapp.label[lang];
---
<a
  href={href}
  target="_blank"
  rel="noopener"
  class="fixed bottom-5 left-5 z-40 inline-flex items-center gap-2 rounded-full bg-[#25D366] text-white pl-3 pr-4 py-3 shadow-float hover:brightness-95 transition"
  aria-label={label}
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-1-.3-1.6-.6-2.9-1.2-4.7-4.1-4.9-4.3-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.5-.3.3c-.1.1-.2.3-.1.5s.5.9 1.1 1.4c.8.7 1.4.9 1.6 1 .2.1.3.1.5-.1l.6-.7c.2-.2.3-.2.5-.1l1.9.9c.2.1.4.2.4.3.1.1.1.6-.1 1.2Z" />
  </svg>
  <span class="hidden sm:inline text-sm font-medium">WhatsApp</span>
</a>
