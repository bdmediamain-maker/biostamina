---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, type Lang } from '@/lib/i18n';
import TrustRow from '@/components/layout/TrustRow.astro';
import GlowCard from '@/components/ui/GlowCard.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const it = lang === 'it';

// Testimonianza Istituto Antropos (Prot. 33SP/2015, Lugano 5 novembre 2015).
// ⚠️ È un'ATTESTAZIONE, non uno studio clinico controllato né un test in vitro:
// la card la presenta come tale ed è accompagnata da un disclaimer, perché il
// documento contiene claim forti (qualità curative, −50% tempi di guarigione
// rispetto ad altri farmaci) riferiti a pazienti umani.
const antroposPdf = it
  ? '/docs/antropos-testimonianza-2015-it.pdf'
  : '/docs/antropos-testimonial-2015-en.pdf';

const items = it
  ? [
      { h: 'Marcatura CE', d: 'Tutti i dispositivi della linea Bio RIGENERA® O3 sono marcati CE e autorizzati come dispositivi medici a uso topico.' },
      { h: 'Classe IIa / IIb', d: 'Dental è classe IIa; Cicatren e Dermal sono classe IIb. La classe indica il livello di rischio e il percorso di conformità del dispositivo.' },
      { h: 'Notifica al Ministero della Salute', d: 'Dispositivi notificati al Ministero della Salute italiano. CND M040499 — medicazioni per ferite, piaghe e ulcere e cavo orale.' },
      { h: 'Brevetti di rigenerazione (2017)', d: 'La tecnologia degli oli essenziali ozonizzati è coperta da brevetti depositati.' },
    ]
  : [
      { h: 'CE marking', d: 'All Bio RIGENERA® O3 devices are CE-marked and authorised as medical devices for topical use.' },
      { h: 'Class IIa / IIb', d: 'Dental is class IIa; Cicatren and Dermal are class IIb. The class reflects the risk level and conformity route of the device.' },
      { h: 'Notified to the Ministry of Health', d: 'Devices notified to the Italian Ministry of Health. CND M040499 — dressings for wounds, sores and ulcers and the oral cavity.' },
      { h: 'Regeneration patents (2017)', d: 'The ozonated essential-oil technology is covered by filed patents.' },
    ];
---
<BaseLayout title={`${t('nav.certifications')} — Biostamina`} description={it ? 'CE e uso topico, classe IIa/IIb, notifica al Ministero (CND M040499), Istituto Antropos di Lugano e brevetti di rigenerazione.' : 'CE and topical use, class IIa/IIb, Ministry notification (CND M040499), Antropos Institute in Lugano and regeneration patents.'}>
  <div class="mx-auto max-w-4xl px-5 py-14">
    <p class="label-mono text-primary mb-3">E-E-A-T</p>
    <h1 class="text-4xl md:text-5xl mb-4">{t('nav.certifications')}</h1>
    <p class="text-muted mb-10 max-w-2xl">{it
      ? 'La credibilità di Bio RIGENERA® poggia su certificazioni verificabili e su testimonianze cliniche indipendenti.'
      : 'The credibility of Bio RIGENERA® rests on verifiable certifications and independent clinical attestations.'}</p>

    <div class="mb-8"><TrustRow /></div>

    <!-- Card Istituto Antropos — cliccabile, apre la testimonianza in un popup -->
    <button
      type="button"
      data-antropos-open
      class="w-full text-left rounded-[--radius-card] border border-hairline bg-surface p-6 mb-12 hover:border-primary transition-colors group"
      data-reveal
    >
      <div class="flex items-start gap-4">
        <!-- bandiera svizzera rettangolare (3:2) -->
        <span class="shrink-0 w-9 h-6 rounded-[3px] overflow-hidden border border-hairline mt-0.5" aria-hidden="true">
          <svg viewBox="0 0 36 24" class="block w-full h-full">
            <rect width="36" height="24" fill="#D52B1E" />
            <rect x="15" y="5" width="6" height="14" fill="#fff" />
            <rect x="11" y="9" width="14" height="6" fill="#fff" />
          </svg>
        </span>
        <div class="min-w-0">
          <p class="label-mono text-primary mb-1">{it ? 'Testato da' : 'Tested by'}</p>
          <h2 class="text-xl leading-snug">Istituto Antropos S.A.</h2>
          <p class="text-sm text-ink/80 leading-relaxed mt-1">{it
            ? 'Istituto di Ricerca nel Campo Medico Farmacologico — CH 6900 Lugano, Svizzera.'
            : 'Research Institute in the Medical-Pharmacological Field — CH 6900 Lugano, Switzerland.'}</p>
          <span class="mt-3 inline-flex items-center gap-1.5 text-sm text-azure group-hover:underline">
            {it ? 'Leggi la testimonianza (2015)' : 'Read the attestation (2015)'} →
          </span>
        </div>
      </div>
    </button>

    <div class="space-y-4">
      {items.map((i) => (
        <GlowCard as="article" class="rounded-[--radius-card] border border-hairline bg-surface p-6" data-reveal>
          <h2 class="text-xl mb-2">{i.h}</h2>
          <p class="text-sm text-ink/80 leading-relaxed">{i.d}</p>
        </GlowCard>
      ))}
    </div>

    {/* ⚠️ COMPLIANCE: il Pet NON è elencato tra i dispositivi medici — è un
        fitoterapico veterinario con marcatura CE (bugiardino + addendum 3). */}
    <div class="section-blue mt-12 rounded-[--radius-card] border p-6 md:p-8 shadow-soft" data-reveal>
      <h2 class="text-lg mb-2">{it ? 'Dispositivo medico vs cosmetico' : 'Medical device vs cosmetic'}</h2>
      <p class="text-sm text-muted leading-relaxed">{it
        ? 'La linea Bio RIGENERA® O3 (Dental, Cicatren, Dermal) è composta da dispositivi medici CE ad uso topico. Bio RIGENERA® Pet è un prodotto fitoterapico veterinario professionale con marcatura CE. Il dermocosmetico Anti-Age è invece un siero al 100% naturale di soli 20 oli essenziali di piante medicinali con stem cell di Gardenia: nutre, protegge e migliora l’aspetto della pelle, stimolando i fibroblasti alla naturale produzione del collagene al riempimento delle rughe.'
        : 'The Bio RIGENERA® O3 range (Dental, Cicatren, Dermal) consists of CE medical devices for topical use. Bio RIGENERA® Pet is a professional veterinary phytotherapeutic product with CE marking. The Anti-Age dermocosmetic is instead a 100% natural serum of only 20 essential oils from medicinal plants with Gardenia stem cells: it nourishes, protects and improves the appearance of the skin, stimulating fibroblasts towards the natural production of collagen to fill wrinkles.'}</p>
    </div>

    <!-- ⚠️ TODO cliente: numero brevetto completo (Brev. No. 102018000…) e certificati CE in PDF -->
  </div>

  <!-- Popup testimonianza Antropos — 3/4 della pagina -->
  <div id="antropos-modal" class="fixed inset-0 z-[80] hidden items-center justify-center p-4" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Istituto Antropos">
    <div data-antropos-backdrop class="absolute inset-0 bg-ink/60"></div>
    <div class="relative w-[75vw] h-[75vh] max-w-5xl bg-paper rounded-[--radius-card] shadow-2xl flex flex-col overflow-hidden">
      <header class="flex items-center justify-between gap-4 px-5 py-3 border-b border-hairline shrink-0">
        <div class="min-w-0">
          <p class="text-sm font-medium truncate">Istituto Antropos S.A. — {it ? 'testimonianza' : 'attestation'} (2015)</p>
          <p class="text-xs text-muted truncate">{it ? 'Prot. 33SP/2015 · Lugano, 5 novembre 2015' : 'Ref. 33SP/2015 · Lugano, 5 November 2015'}</p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <a href={antroposPdf} target="_blank" rel="noopener" class="text-sm text-azure hover:underline">{it ? 'Apri il PDF' : 'Open PDF'} ↗</a>
          <button type="button" data-antropos-close class="w-9 h-9 grid place-items-center rounded-full hover:bg-tint transition" aria-label={it ? 'Chiudi' : 'Close'}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </header>
      <iframe data-antropos-frame title="Istituto Antropos" class="flex-1 w-full bg-tint" src="about:blank"></iframe>
      <p class="px-5 py-2.5 text-[11px] text-muted leading-snug border-t border-hairline shrink-0">{it
        ? 'Documento di attestazione rilasciato dall’Istituto Antropos S.A. (2015). Non costituisce uno studio clinico controllato: le esperienze riportate sono individuali e non garantiscono i medesimi risultati.'
        : 'Attestation document issued by Istituto Antropos S.A. (2015). It is not a controlled clinical study: the experiences reported are individual and do not guarantee the same results.'}</p>
    </div>
  </div>

  <script is:inline define:vars={{ antroposPdf }}>
    (() => {
      const modal = document.getElementById('antropos-modal');
      if (!modal) return;
      const frame = modal.querySelector('[data-antropos-frame]');
      const open = () => {
        // il PDF si carica solo all'apertura (niente peso inutile al load)
        if (frame.getAttribute('src') === 'about:blank') frame.setAttribute('src', antroposPdf);
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        modal.setAttribute('aria-hidden', 'false');
        document.documentElement.style.overflow = 'hidden';
      };
      const close = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modal.setAttribute('aria-hidden', 'true');
        document.documentElement.style.overflow = '';
      };
      document.querySelectorAll('[data-antropos-open]').forEach((b) => b.addEventListener('click', open));
      modal.querySelectorAll('[data-antropos-close]').forEach((b) => b.addEventListener('click', close));
      modal.querySelector('[data-antropos-backdrop]').addEventListener('click', close);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    })();
  </script>
</BaseLayout>
