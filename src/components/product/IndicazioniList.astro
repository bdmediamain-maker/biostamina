---
import { getLangFromUrl, useTranslations } from '@/lib/i18n';

interface Props { items: string[] }
const { items } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
{items.length > 0 && (
  <section aria-labelledby="indic-h" data-reveal>
    <h2 id="indic-h" class="text-xl mb-4">{t('product.indications')}</h2>
    <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-2">
      {items.map((it) => (
        <li class="flex gap-2.5 text-sm text-ink/85 leading-snug">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary shrink-0 mt-0.5" aria-hidden="true"><path d="M4 12l5 5L20 6" /></svg>
          <span>{it}</span>
        </li>
      ))}
    </ul>
  </section>
)}
