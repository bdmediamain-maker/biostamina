---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, localePath, type Lang } from '@/lib/i18n';
import ProductCard from '@/components/product/ProductCard.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const products = (await getCollection('products', (p) => !p.data.draft)).sort((a, b) => a.data.order - b.data.order);

// categorie presenti (per il filtro)
const categories = [...new Set(products.map((p) => p.data.category))];

// Due linee dalla molecola ProRigenera (addendum 2 §2)
const it = lang === 'it';
const groups = [
  {
    line: 'dispositivi-medici',
    title: 'BioRigenera® Medical',
    desc: it
      ? 'Dispositivi Medici medicamentosi biorigeneranti e bioriparatori a base di molecole di ozono e oli essenziali, notificati al Ministero della Salute Italiano, studiati per supportare i fisiologici processi di riparazione dei tessuti.'
      : 'Medicated medical devices, bio-regenerating and bio-repairing, based on ozone molecules and essential oils, notified to the Italian Ministry of Health, designed to support the physiological tissue-repair processes.',
    items: products.filter((p) => p.data.line === 'dispositivi-medici'),
  },
  {
    line: 'stem-cells',
    title: t('line.stemCells'),
    desc: it
      ? 'Linea rigenerativa alle cellule staminali vegetali (brevetti ProRigenera): cosmetica anti-age e veterinario professionale.'
      : 'Regenerative line with plant stem cells (ProRigenera patents): anti-age cosmetics and professional veterinary.',
    items: products.filter((p) => p.data.line === 'stem-cells'),
  },
].filter((g) => g.items.length > 0);
---
<BaseLayout title={`${t('nav.shop')} — Biostamina`} description={lang === 'it' ? 'La linea Bio RIGENERA® O3: dispositivi medici CE per odontoiatria, cicatrizzazione e dermatologia.' : 'The Bio RIGENERA® O3 range: CE medical devices for dentistry, wound healing and dermatology.'}>
  <div class="mx-auto max-w-7xl px-5 py-12">
    <nav class="text-sm text-muted mb-4" aria-label="Breadcrumb">
      <a href={localePath(lang)} class="hover:text-primary">{t('nav.home')}</a>
      <span class="mx-1.5">/</span><span class="text-ink/70">{t('nav.shop')}</span>
    </nav>
    <h1 class="text-4xl md:text-5xl mb-3">{t('nav.shop')}</h1>
    <p class="text-muted max-w-2xl mb-6">{it ? 'Due linee nate dalla molecola brevettata ProRigenera: i dispositivi medici all’ozono e la linea rigenerativa alle cellule staminali.' : 'Two lines born from the patented ProRigenera molecule: the ozone medical devices and the regenerative stem-cell line.'}</p>

    <div class="flex flex-wrap gap-2 mb-10" role="group" aria-label="Filtro categorie">
      <button type="button" class="cat-btn label-mono px-3 py-1.5 rounded-full" data-filter="all" aria-pressed="true">{it ? 'Tutti' : 'All'}</button>
      {categories.map((c) => (
        <button type="button" class="cat-btn label-mono px-3 py-1.5 rounded-full normal-case tracking-normal" data-filter={c} aria-pressed="false">{c}</button>
      ))}
    </div>

    <div data-product-grid class="space-y-14">
      {groups.map((g) => (
        <section data-line-group aria-labelledby={`line-${g.line}`}>
          <div class="mb-6">
            <h2 id={`line-${g.line}`} class="text-2xl md:text-3xl">{g.title}</h2>
            <p class="text-sm text-muted mt-1 max-w-2xl">{g.desc}</p>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {g.items.map((p) => <ProductCard product={p} />)}
          </div>
        </section>
      ))}
    </div>

    <p data-no-results hidden class="text-muted mt-8">{it ? 'Nessun prodotto in questa categoria.' : 'No products in this category.'}</p>
  </div>

  <style>
    .cat-btn {
      border: 1px solid var(--color-hairline);
      color: var(--color-muted);
      background: transparent;
      cursor: pointer;
      transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }
    .cat-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
    .cat-btn[aria-pressed="true"] {
      background: var(--color-primary);
      color: #fff;
      border-color: transparent;
    }
  </style>

  <script>
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-btn'));
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-product-grid] .product-item'));
    const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-line-group]'));
    const noResults = document.querySelector<HTMLElement>('[data-no-results]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
        let visible = 0;
        items.forEach((it) => {
          const show = filter === 'all' || it.dataset.category === filter;
          it.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        // Nasconde una sezione-linea se non ha prodotti visibili
        groups.forEach((g) => {
          const anyVisible = Array.from(g.querySelectorAll<HTMLElement>('.product-item')).some((it) => it.style.display !== 'none');
          g.style.display = anyVisible ? '' : 'none';
        });
        if (noResults) noResults.hidden = visible > 0;
      });
    });
  </script>
</BaseLayout>
