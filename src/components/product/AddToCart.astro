---
/**
 * AddToCart + "Chiedi info su WhatsApp".
 * ⚠️ WhatsApp è SOLO canale INFO (per ora il cliente non vuole ordini via WhatsApp).
 * Woo headless (stub): quando lo Store API non è configurato il carrello è disabilitato.
 */
import { getLangFromUrl, useTranslations } from '@/lib/i18n';
import { site } from '@/config/site';
import { wooEnabled } from '@/lib/woo';

interface Props { wooId: number; productName: string; inStock?: boolean; comingSoon?: boolean }
const { wooId, productName, inStock = true, comingSoon = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const waText = encodeURIComponent(
  lang === 'it'
    ? `Ciao, vorrei informazioni su: ${productName}`
    : `Hello, I'd like information about: ${productName}`,
);
const waHref = `https://wa.me/${site.whatsapp.number}?text=${waText}`;
const cartActive = wooEnabled && wooId > 0 && inStock;
---
{comingSoon ? (
  <div class="flex flex-col gap-3">
    <!-- Waitlist "Avvisami quando torna" (addendum 3 §2) -->
    <form action={site.formspree.notify} method="POST" class="flex flex-col sm:flex-row gap-3">
      <input type="hidden" name="_subject" value={`Waitlist Anti-Age — ${productName}`} />
      <input type="hidden" name="prodotto" value={productName} />
      <input
        required
        type="email"
        name="email"
        placeholder={t('product.notifyPlaceholder')}
        class="flex-1 rounded-full border border-hairline bg-surface px-5 py-3.5 text-sm focus:border-primary outline-none"
      />
      <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-full bg-primary text-white px-6 py-3.5 text-sm font-medium hover:bg-primary-dark transition shrink-0">
        {t('product.notify')} →
      </button>
    </form>
    <a href={waHref} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 self-start rounded-full px-6 py-3 text-sm font-medium border border-[#25D366] text-[#128C4B] hover:bg-[#25D366]/10 transition">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Z"/></svg>
      {t('cta.whatsapp')}
    </a>
    <p class="text-xs text-muted">⚠️ Formspree waitlist da configurare in <code>src/config/site.ts</code>.</p>
  </div>
) : (
<div class="flex flex-col sm:flex-row gap-3">
  {cartActive ? (
    <button
      type="button"
      data-woo-add={wooId}
      class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-medium transition bg-primary text-white hover:bg-primary-dark disabled:opacity-60"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
        <circle cx="9" cy="20" r="1" /><circle cx="18" cy="20" r="1" />
        <path d="M2 3h2l2.4 12.5a2 2 0 0 0 2 1.5h8.7a2 2 0 0 0 2-1.6L22 7H6" />
      </svg>
      <span data-cart-label>{t('cta.cart')}</span>
    </button>
  ) : (
    <button
      type="button"
      disabled
      class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-medium transition bg-hairline text-muted cursor-not-allowed"
      title={lang === 'it' ? 'Checkout online in arrivo' : 'Online checkout coming soon'}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
        <circle cx="9" cy="20" r="1" /><circle cx="18" cy="20" r="1" />
        <path d="M2 3h2l2.4 12.5a2 2 0 0 0 2 1.5h8.7a2 2 0 0 0 2-1.6L22 7H6" />
      </svg>
      {t('cta.cart')}
    </button>
  )}

  <a
    href={waHref}
    target="_blank"
    rel="noopener"
    class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-medium border border-[#25D366] text-[#128C4B] hover:bg-[#25D366]/10 transition"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-1-.3-1.6-.6-2.9-1.2-4.7-4.1-4.9-4.3-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.1.1.3 0 .5l-.4.5-.3.3c-.1.1-.2.3-.1.5s.5.9 1.1 1.4c.8.7 1.4.9 1.6 1 .2.1.3.1.5-.1l.6-.7c.2-.2.3-.2.5-.1l1.9.9c.2.1.4.2.4.3.1.1.1.6-.1 1.2Z" />
    </svg>
    {t('cta.whatsapp')}
  </a>
</div>
)}

<script>
  import { cartApi, openCart } from '@/lib/cart';

  document.querySelectorAll<HTMLButtonElement>('[data-woo-add]').forEach((btn) => {
    const label = btn.querySelector<HTMLElement>('[data-cart-label]');
    const original = label?.textContent ?? '';
    btn.addEventListener('click', async () => {
      const id = Number(btn.dataset.wooAdd);
      if (!id) return;
      btn.disabled = true;
      try {
        await cartApi.add(id, 1);
        if (label) label.textContent = document.documentElement.lang === 'en' ? 'Added ✓' : 'Aggiunto ✓';
        openCart();
      } catch {
        if (label) label.textContent = document.documentElement.lang === 'en' ? 'Error, retry' : 'Errore, riprova';
      } finally {
        setTimeout(() => { if (label) label.textContent = original; btn.disabled = false; }, 1600);
      }
    });
  });
</script>
