---
/**
 * "Cosa dicono i professionisti" — recensioni di medici/studi in evidenza.
 * Asset E-E-A-T più forte (Dr. Morella, Filippo d'Alfonso, Dental Bios Srl).
 */
import { getLangFromUrl, useTranslations } from '@/lib/i18n';
import { proReviews } from '@/data/reviews';
import ReviewStars from '@/components/product/ReviewStars.astro';

interface Props { product?: string; title?: string }
const { product, title: titleProp } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pros = proReviews().filter((r) => !product || r.product === product);
const title = titleProp ?? (lang === 'it' ? 'Cosa dicono i professionisti' : 'What professionals say');
---
{pros.length > 0 && (
  <section class="mx-auto max-w-7xl px-5 py-16" aria-labelledby="pro-h">
    <h2 id="pro-h" class="text-3xl md:text-4xl mb-3" data-reveal>{title}</h2>
    <p class="text-muted mb-8 max-w-2xl" data-reveal>
      {lang === 'it'
        ? 'Dentisti, studi odontoiatrici e specialisti che usano Bio RIGENERA® nei protocolli clinici quotidiani.'
        : 'Dentists, dental practices and specialists using Bio RIGENERA® in daily clinical protocols.'}
    </p>
    <div class="grid gap-5 md:grid-cols-3">
      {pros.map((r) => (
        <figure class="rounded-[--radius-card] border border-hairline bg-surface p-6 flex flex-col" data-reveal>
          <ReviewStars rating={r.rating} showCount={false} size={15} />
          <blockquote class="mt-3 text-sm text-ink/85 leading-relaxed flex-1">“{r.text}”</blockquote>
          <figcaption class="mt-4 pt-4 border-t border-hairline">
            <span class="font-medium text-ink block">{r.author}</span>
            <span class="text-sm text-muted">{r.role}</span>
            {r.roleUrl && <a href={r.roleUrl} target="_blank" rel="noopener" class="block text-xs text-azure hover:underline mt-0.5">{r.roleUrl.replace('https://', '')}</a>}
          </figcaption>
        </figure>
      ))}
    </div>
    <p class="mt-5 text-xs text-muted italic">{t('reviews.disclaimer')}</p>
  </section>
)}
