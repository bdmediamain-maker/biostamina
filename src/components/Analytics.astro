---
/**
 * Consenso + Analytics — replica esatta del setup del sito attuale.
 *
 * - Iubenda Cookie Solution (siteId 3996940, cookiePolicyId 24179786) — TCF v2
 *   + Google Additional Consent Mode, banner dark top-center (config identica
 *   a quella live su biostamina.net).
 * - Google Consent Mode v2: default "denied" PRIMA di gtag → conforme GDPR;
 *   Iubenda concede il consenso quando l'utente accetta.
 * - GA4 (G-NPV6T6107M) + Google Ads (AW-17105796103), gli stessi ID del sito
 *   attuale → storico conversioni e remarketing invariati.
 *
 * Caricato SOLO in produzione (niente banner/tracking in dev).
 *
 * COMPORTAMENTO BANNER (verificato sul build): appare finché l'utente non
 * sceglie (obbligo di legge); dopo Accetta/Rifiuta il consenso persiste nei
 * cookie e il banner NON riappare al cambio pagina. Il bottone flottante
 * Iubenda è disattivato (si sovrapponeva al widget Assistente): la revoca
 * del consenso passa dal link "Preferenze cookie" nel footer.
 */
import { getLangFromUrl } from '@/lib/i18n';
const prod = import.meta.env.PROD;
const lang = getLangFromUrl(Astro.url);
---
{prod && (
  <Fragment>
    {/* Google Consent Mode v2 — default negato finché l'utente non acconsente */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500
      });
      gtag('js', new Date());
      gtag('config', 'G-NPV6T6107M');
      gtag('config', 'AW-17105796103');
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NPV6T6107M"></script>

    {/* Iubenda Cookie Solution — config del sito attuale, con due differenze:
        niente bottone flottante (revoca dal link "Preferenze cookie" nel footer)
        e lingua del banner allineata alla lingua della pagina. */}
    <script is:inline define:vars={{ bannerLang: lang }}>
      var _iub = _iub || [];
      _iub.csConfiguration = {"floatingPreferencesButtonDisplay":false,"lang":bannerLang,"siteId":3996940,"cookiePolicyId":24179786,"whitelabel":true,"banner":{"closeButtonDisplay":false,"listPurposes":true,"explicitWithdrawal":true,"rejectButtonDisplay":true,"acceptButtonDisplay":true,"customizeButtonDisplay":true,"closeButtonRejects":true,"position":"float-top-center","style":"dark"},"perPurposeConsent":true,"googleAdditionalConsentMode":true,"enableTcf":true,"tcfPurposes":{"1":true,"2":"consent_only","3":"consent_only","4":"consent_only","5":"consent_only","6":"consent_only","7":"consent_only","8":"consent_only","9":"consent_only","10":"consent_only"}};
    </script>
    {/* Nasconde il marchio Iubenda nel banner. whitelabel:true lo toglie se il
        piano Iubenda del cliente lo include; questo CSS è la rete di sicurezza.
        ⚠️ NB: senza l'opzione whitelabel nel piano, nascondere il brand è contro
        i ToS Iubenda — verificare il piano del cliente. */}
    <style is:inline>
      #iubenda-cs-banner .iubenda-cs-brand,
      #iubenda-cs-banner [class*="logo-container"],
      .iubenda-cs-brand { display: none !important; }
    </style>
    <script is:inline type="text/javascript" src="https://cdn.iubenda.com/cs/tcf/stub-v2.js"></script>
    <script is:inline type="text/javascript" src="https://cdn.iubenda.com/cs/tcf/safe-tcf-v2.js"></script>
    <script is:inline type="text/javascript" src="https://cdn.iubenda.com/cs/iubenda_cs.js" charset="UTF-8" async></script>
  </Fragment>
)}
