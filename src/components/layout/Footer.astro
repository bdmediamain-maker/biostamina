---
import { getLangFromUrl, useTranslations, localePath } from '@/lib/i18n';
import { getImage } from 'astro:assets';
import { site } from '@/config/site';
import Logo from '@/components/nav/Logo.astro';
import studioImg from '@/assets/team/studio-microscopio.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = 2026;

// Foto studio come sfondo del footer (ottimizzata webp)
const studio = await getImage({ src: studioImg, width: 1800, format: 'webp' });

const cols = [
  {
    title: t('nav.products'),
    links: [
      { href: localePath(lang, 'negozio'), label: t('nav.shop') },
      { href: localePath(lang, 'prodotto/dental'), label: 'Bio RIGENERA® Dental' },
      { href: localePath(lang, 'prodotto/cicatren'), label: 'Bio RIGENERA® Cicatren' },
      { href: localePath(lang, 'prodotto/dermal'), label: 'Bio RIGENERA® Dermal' },
    ],
  },
  {
    title: 'Biostamina',
    links: [
      { href: localePath(lang, 'chi-siamo'), label: t('nav.about') },
      { href: localePath(lang, 'certificazioni'), label: t('nav.certifications') },
      { href: localePath(lang, 'come-si-usa'), label: t('nav.howto') },
      { href: localePath(lang, 'professionisti'), label: t('nav.professionals') },
    ],
  },
  {
    title: t('footer.legal'),
    links: [
      { href: localePath(lang, 'legal/privacy'), label: 'Privacy' },
      { href: localePath(lang, 'legal/termini'), label: lang === 'it' ? 'Termini' : 'Terms' },
      { href: localePath(lang, 'legal/rimborsi'), label: lang === 'it' ? 'Rimborsi' : 'Refunds' },
      { href: localePath(lang, 'legal/cookie'), label: 'Cookie' },
    ],
  },
];
---
<footer class="relative mt-24 border-t border-hairline overflow-hidden">
  <!-- Sfondo: foto studio odontoiatrico -->
  <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${studio.src}')`} aria-hidden="true"></div>
  <!-- Overlay sfumato (più forte in basso) per leggibilità del testo -->
  <div class="absolute inset-0" aria-hidden="true" style="background: linear-gradient(to bottom, rgba(247,249,252,0.78) 0%, rgba(247,249,252,0.85) 55%, rgba(247,249,252,0.94) 100%);"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 py-14 grid gap-10 md:grid-cols-4">
    <div>
      <Logo height={56} class="h-14" linked={false} />
      <p class="mt-3 text-sm text-muted leading-relaxed">{site.tagline[lang]}</p>
      {site.social.yt && (
        <a href={site.social.yt} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-2 text-sm text-azure hover:underline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.8-1.8C19.3 5 12 5 12 5s-7.3 0-8.8.5A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.8 1.8C4.7 19 12 19 12 19s7.3 0 8.8-.5a2.5 2.5 0 0 0 1.8-1.8C23 15.2 23 12 23 12ZM10 15V9l5 3-5 3Z"/></svg>
          YouTube
        </a>
      )}
    </div>

    {cols.map((col) => (
      <div>
        <p class="label-mono text-muted mb-3">{col.title}</p>
        <ul class="space-y-2">
          {col.links.map((l) => (
            <li><a href={l.href} class="text-sm text-ink/80 hover:text-primary transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="relative z-10 border-t border-hairline">
    <div class="mx-auto max-w-7xl px-5 py-6 text-xs text-muted space-y-2">
      <p class="leading-relaxed">{t('footer.medicalNote')}</p>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 pt-2">
        <p>
          <span class="font-medium text-ink/80">{t('footer.manufacturer')}:</span> {site.manufacturer.name}, {site.manufacturer.addr}
          &nbsp;·&nbsp;
          <span class="font-medium text-ink/80">{t('footer.seller')}:</span> {site.seller.name}, P.IVA {site.seller.vat}
        </p>
        <p>© {year} {site.name}. {t('footer.rights')}</p>
      </div>
    </div>
  </div>
</footer>
