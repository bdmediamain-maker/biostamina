---
/**
 * Consenso + Analytics — replica esatta del setup del sito attuale.
 *
 * - Iubenda Cookie Solution (siteId 3996940, cookiePolicyId 24179786) — TCF v2
 *   + Google Additional Consent Mode, banner dark top-center (config identica
 *   a quella live su biostamina.net).
 * - Google Consent Mode v2: default "denied" PRIMA di gtag → conforme GDPR;
 *   Iubenda concede il consenso quando l'utente accetta.
 * - GA4 (G-NPV6T6107M) + Google Ads (AW-17105796103), gli stessi ID del sito
 *   attuale → storico conversioni e remarketing invariati.
 *
 * Caricato SOLO in produzione (niente banner/tracking in dev).
 */
const prod = import.meta.env.PROD;
---
{prod && (
  <Fragment>
    {/* Google Consent Mode v2 — default negato finché l'utente non acconsente */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500
      });
      gtag('js', new Date());
      gtag('config', 'G-NPV6T6107M');
      gtag('config', 'AW-17105796103');
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NPV6T6107M"></script>

    {/* Iubenda Cookie Solution — config identica al sito attuale */}
    <script is:inline>
      var _iub = _iub || [];
      _iub.csConfiguration = {"floatingPreferencesButtonDisplay":"bottom-right","lang":"it","siteId":3996940,"cookiePolicyId":24179786,"whitelabel":false,"banner":{"closeButtonDisplay":false,"listPurposes":true,"explicitWithdrawal":true,"rejectButtonDisplay":true,"acceptButtonDisplay":true,"customizeButtonDisplay":true,"closeButtonRejects":true,"position":"float-top-center","style":"dark"},"perPurposeConsent":true,"googleAdditionalConsentMode":true,"enableTcf":true,"tcfPurposes":{"1":true,"2":"consent_only","3":"consent_only","4":"consent_only","5":"consent_only","6":"consent_only","7":"consent_only","8":"consent_only","9":"consent_only","10":"consent_only"}};
    </script>
    <script is:inline type="text/javascript" src="https://cdn.iubenda.com/cs/tcf/stub-v2.js"></script>
    <script is:inline type="text/javascript" src="https://cdn.iubenda.com/cs/tcf/safe-tcf-v2.js"></script>
    <script is:inline type="text/javascript" src="https://cdn.iubenda.com/cs/iubenda_cs.js" charset="UTF-8" async></script>
  </Fragment>
)}
