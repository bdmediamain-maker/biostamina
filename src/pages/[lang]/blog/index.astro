---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, localePath, type Lang } from '@/lib/i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const it = lang === 'it';

const all = (await getCollection('blog', (p) => !p.data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
// Divisione a parte richiesta dal cliente: i protocolli professionali
// (ex pagina "Come si usa") vivono in un proprio blocco, separato dagli articoli.
const ADVICE_CLUSTER = 'Il consiglio del medico';
const advice = all.filter((p) => p.data.cluster === ADVICE_CLUSTER);
const posts = all.filter((p) => p.data.cluster !== ADVICE_CLUSTER);
---
<BaseLayout title={`${t('nav.blog')} — Biostamina`} description={it ? 'Approfondimenti su rigenerazione tissutale, cura delle ferite, salute orale e dermatologia.' : 'Insights on tissue regeneration, wound care, oral health and dermatology.'}>
  <div class="mx-auto max-w-5xl px-5 py-14">
    <h1 class="text-4xl md:text-5xl mb-4">{t('nav.blog')}</h1>
    <p class="text-muted mb-10 max-w-2xl">{it ? 'Contenuti divulgativi a supporto dei prodotti Bio RIGENERA®.' : 'Educational content supporting the Bio RIGENERA® products.'}</p>

    {/* Divisione dedicata: protocolli professionali di medicazione */}
    {advice.length > 0 && (
      <section class="mb-14" aria-labelledby="advice-h">
        <h2 id="advice-h" class="text-2xl md:text-3xl mb-2" data-reveal>{it ? 'Il consiglio del medico sulle medicazioni' : 'The doctor’s advice on dressings'}</h2>
        <p class="text-sm text-muted mb-6 max-w-2xl" data-reveal>{it ? 'Protocolli d’uso consigliati da odontoiatra, medico e veterinario per i prodotti Bio RIGENERA®.' : 'Usage protocols recommended by the dentist, physician and veterinarian for the Bio RIGENERA® products.'}</p>
        <div class="grid gap-6 sm:grid-cols-2">
          {advice.map((post) => {
            const loc = post.data[lang];
            return (
              <a href={localePath(lang, `blog/${post.id}`)} class="rounded-[--radius-card] border border-hairline bg-tint/40 p-6 hover:shadow-soft transition-shadow" data-reveal>
                <span class="label-mono text-primary">{post.data.cluster}</span>
                <h3 class="text-xl mt-2 mb-2">{loc.title}</h3>
                <p class="text-sm text-muted leading-relaxed">{loc.description}</p>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {advice.length > 0 && posts.length > 0 && (
      <h2 class="text-2xl md:text-3xl mb-6" data-reveal>{it ? 'Articoli' : 'Articles'}</h2>
    )}

    {posts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => {
          const loc = post.data[lang];
          return (
            <a href={localePath(lang, `blog/${post.id}`)} class="rounded-[--radius-card] border border-hairline bg-surface p-6 hover:shadow-soft transition-shadow" data-reveal>
              <span class="label-mono text-primary">{post.data.cluster}</span>
              <h2 class="text-xl mt-2 mb-2">{loc.title}</h2>
              <p class="text-sm text-muted leading-relaxed">{loc.description}</p>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="rounded-[--radius-card] border border-hairline bg-tint/40 p-10 text-center" data-reveal>
        <p class="text-ink font-medium">{it ? 'Articoli in arrivo.' : 'Articles coming soon.'}</p>
        <p class="text-sm text-muted mt-1">{it ? 'Gli 11 articoli del blog verranno migrati con cluster e versione EN.' : 'The 11 blog articles will be migrated with clusters and EN versions.'}</p>
      </div>
    )}
  </div>
</BaseLayout>
